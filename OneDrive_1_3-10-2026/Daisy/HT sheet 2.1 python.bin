   "cell_type": "code",
   "execution_count": null,
   "id": "c7f69306",
   "metadata": {},
   "outputs": [],
   "source": [
    "import math \n",
    "\n",
    "#part a\n",
    "\n",
    "def f(x):\n",
    "   return(math.sin(x)*math.sinh(x))\n",
    "\n",
    "def f_derivative(x):\n",
    "    return(math.cos(x)*math.sinh(x) + math.sin(x)*math.cosh(x))\n",
    "\n",
    "x_0 = 0.5\n",
    "tol = 1e-8\n",
    "\n",
    "for i in range(1000): #max 1000 iterations\n",
    " fx = f(x_0)\n",
    " dfx = f_derivative(x_0)\n",
    " if abs(fx)<tol:\n",
    "    break\n",
    " x_0 = x_0 - (fx/dfx)\n",
    "\n",
    "print(\"The root is\", x_0)\n",
    "\n",
    "#part b\n",
    "\n",
    "def g(x):\n",
    "   return(x - math.sin(x))\n",
    "\n",
    "def derivative_g(x):\n",
    "   return(1 - math.cos(x))\n",
    "\n",
    "y_0 = 0.5\n",
    "  \n",
    "for i in range(1000):\n",
    " dgx = derivative_g(y_0)\n",
    " gx = g(y_0)\n",
    " if abs(gx)<tol:\n",
    "  break\n",
    " y_0 = y_0 - (gx/dgx)\n",
    "\n",
    "print(\"The root is\", y_0)\n",
    "\n",
    "\n",
    "   \n",
    "\n",
    "#part c\n",
    "\n",
    "def h(x):\n",
    "   return(x*math.cos(x))\n",
    "\n",
    "def h_derivative(x):\n",
    "   return(math.cos(x)-x*math.sin(x))\n",
    "\n",
    "z_0 = 0.5\n",
    "\n",
    "for i in range(1000):\n",
    " hx = h(z_0)\n",
    " dhx = h_derivative(z_0)\n",
    " if abs(hx)<tol:\n",
    "  break\n",
    " z_0 = z_0 - (hx/dhx)\n",
    "\n",
    "print(\"the root is\", z_0)"
   ]
  }
 ],
